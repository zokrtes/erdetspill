; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="erdetetspill"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=144
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://ledttnlru0gb"

[autoload]

GameManager="*uid://ca5p132orrmfs"
DialogueUI="*res://scenes/ui/dialogue_ui.tscn"
PauseMenu="*res://scenes/ui/pause_menu.tscn"
InventoryHintOnce="*res://scenes/ui/inventory_hint_once.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/size/resizable=false
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/3dEnemyToolkit/plugin.cfg", "res://addons/proton_scatter/plugin.cfg", "res://addons/road-generator/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "red",
"res://assets/": "green",
"res://levels/": "orange",
"res://scenes/": "blue"
}

[importer_defaults]

animation_library={
&"fbx/importer": 1
}

