reward_items = Array[String](["approved_application"])
unlock_quests = Array[String](["BANK_DEPOSIT"])
offer_dialogue = Array[String](["Yo.", "Stipend?", "Ja, det fikser vi.", "Se den stasjonen til høyre for deg?", "Gå dit og fyll ut skjemaet.", "Send inn når du er ferdig.", "Enkelt."])
completion_dialogue = Array[String](["Skjemaet er godkjent.", "Her er stipendet ditt. Bruk det klokt."])
