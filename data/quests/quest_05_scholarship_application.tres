[resource]
script = ExtResource("2_fdgti")
quest_id = "SCHOLARSHIP_APPLICATION"
name = "Stipend"
description = "Søk stipend hos Lånekassa"
brief_description = "Det finnes kanskje måter å skaffe mer penger på."
required_quest_ids = Array[String](["GRANDPA_DISAPPOINTMENT"])
objectives = Array[ExtResource("1_4xtab")]([SubResource("Resource_fdgti"), SubResource("Resource_b64h0")])
reward_items = Array[String](["approved_application"])
unlock_quests = Array[String](["BANK_DEPOSIT"])
offer_dialogue = Array[String](["Eg er lei av folk som sit og snakkar om at Lånekassen bryr seg ikkje og fikser ingenting.", "Du veit ikkje kva du snakkar om.", "Me sit her kvar dag, behandlar søknadar og held systemet i gang.", "Du trur det er lett? Prøv å handtere tusen studentar som masar om stipend samtidig.", "Stasjonen er til høyre for deg. Fyll ut og send inn."])
completion_dialogue = Array[String](["Godkjent.", "Her er søknaden din."])
