[resource]
script = ExtResource("1_quest")
quest_id = "IVER_BEVIS"
name = "Ivers ære"
description = "Bevis noe for Iver."
brief_description = "Skaff 3 kråkefjær og 1 elgskinn, og lever til Iver."
objectives = Array[ExtResource("2_objective")]([SubResource("Resource_n0f5l"), SubResource("Resource_b7ymj"), SubResource("Resource_deliver")])
reward_items = Array[String](["grus"])
unlock_quests = Array[String](["STEINAR_GRUS"])
offer_dialogue = Array[String](["Du vil ha grus?", "Jeg selger ikke til hvem som helst.", "Steinar og Stein sa at jeg ikke kunne benke 120 kg.", "Det er løgn, men det er ikke poenget.", "Poenget er at du må bevise at du er seriøs.", "Kjøp deg en hagle.", "Gå til Elgveien og skyt fugler og elg.", "Kom tilbake med 3 kråkefjær og 1 elgskinn.", "Da selger jeg grus.", "Ta pistolen min. Du trenger den."])
completion_dialogue = Array[String](["Ikke verst.", "Her er gruset."])
