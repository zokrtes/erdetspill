[resource]
script = ExtResource("1_quest")
quest_id = "IVER_BEVIS"
name = "Ivers ære"
description = "Bevis noe for Iver."
brief_description = "Skaff 3 kråkefjær og 1 elgskinn, og lever til Iver."
objectives = Array[ExtResource("2_objective")]([SubResource("Resource_b7ymj"), SubResource("Resource_lksmv"), SubResource("Resource_doc81")])
reward_items = Array[String](["grus"])
unlock_quests = Array[String](["STEINAR_GRUS"])
offer_dialogue = Array[String](["Jeg har ikke sett deg før?", "Du vil kjøpe grus?", "Er du kompis av Stein og Steinar? Ja det er du. Jeg ser det på det livløse trynet ditt.", "Jeg selger ikke til Stein og Steinar. De sa jeg ikke kunne benke 120 kg. Noe som jeg klarer btw.", "Uansett. Jeg er en rimelig fyr.", "Hvis du lover å ikke gi det til grusbrødrene og signerer petisjonen min", "OG henter meg 3 kråkefjær og 1 elgskinn så skal jeg selge deg grus."])
completion_dialogue = Array[String](["Takk for fjær og skinn, nå blir det suppe!", "Her har du grus som takk, men ikke gi det til Stein og Steinar!"])
